    <string name="credential_gemini_companion_title">Private Gemini CLI companion</string>
    <string name="credential_gemini_companion_body">Keep Google sign-in inside the official Gemini CLI on your computer. CodexBar receives only model labels, used percentages, reset times, tier, and freshness over your local network.</string>
    <string name="credential_gemini_companion_steps">1. Download and start the Gemini companion from this project’s Release on the same Wi-Fi. 2. Scan its QR code with your phone, or paste the pairing code below. 3. Keep the companion running while Gemini monitoring is needed.</string>
    <string name="credential_gemini_pairing_code">Companion pairing code</string>
    <string name="credential_gemini_pairing_hint">Starts with codexbar://gemini-pair. Treat it like a local-device password.</string>
    <string name="credential_gemini_companion_security">No Google access token, refresh token, OAuth client ID, prompt, file, email address, or CLI session content is transferred to Android. The pairing key is encrypted with Android Keystore.</string>
    <string name="credential_cursor_setup_title">Cursor web session</string>
    <string name="credential_cursor_setup_body">Cursor does not provide a supported mobile device-code flow. In a desktop browser signed in to cursor.com, copy the Cookie request header from /api/usage-summary and paste it below. Treat it like a password. CodexBar validates it only against cursor.com, never follows redirects, and encrypts it after validation.</string>
    <string name="credential_cursor_cookie_header">Cursor Cookie header</string>
    <string name="credential_zai_setup_title">z.ai Coding Plan</string>
    <string name="credential_zai_setup_body">Create or copy an API token from the z.ai Coding Plan dashboard. This release connects only to the fixed Global endpoint at api.z.ai; BigModel China and team selectors remain disabled until their region fields can be stored and validated separately.</string>
    <string name="credential_zai_api_key">z.ai API token</string>
